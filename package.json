  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/QuarkOS/Pi-Fusion.git"
  },
  "homepage": "https://github.com/QuarkOS/Pi-Fusion#readme",
  "bugs": {
    "url": "https://github.com/QuarkOS/Pi-Fusion/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ora": "^8.0.1"
