{
  "name": "@quarkos/pi-fusion",
  "version": "1.0.5",
  "description": "Multi-model deliberation harness (OpenRouter Fusion pattern) for OpenCode Go",
  "main": "index.js",
  "type": "module",
  "bin": {
    "pi-fusion": "bin/pi-harness.js"
  },
  "files": [
    "bin/",
    "lib/",
    "index.js",
    "pi-harness.config.json",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
